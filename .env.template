# Required: Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Required: Anthropic API key (for AI fallback on unrecognised GTP formats)
ANTHROPIC_API_KEY=

# Optional: comma-separated Telegram user IDs to restrict access
# Leave blank to allow all users
TELEGRAM_ALLOWED_IDS=

# Optional: parser mode — 'direct' (regex, default) or 'claude' (AI)
PARSER_MODE=direct
