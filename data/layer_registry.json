    "cable_families": ["MV_XLPE_SCREENED"],
    "notes": "Fills interstices between cabled cores; weight = ((π/4×OD_cab²) - n×(π/4×OD_core²)) × fill_factor × density; typical fill_factor 0.87"
  },

  "binding_tape": {
    "display_name": "Binding Tape (over cabling)",
