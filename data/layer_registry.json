    "lay_category": "none",
    "cable_families": ["INSTR_SCREENED", "MV_XLPE_SCREENED"],
    "notes": "PP/polyester tape over cabled assembly before sheath; weight = π × mean_OD × (1+overlap/100) × t × density"
  },

  "binder_tape": {
    "display_name": "Binder Tape (over insulated cores)",
    "formula_type": "tape_wrap",
    "required_inputs": ["mean_od_mm", "tape_thickness_mm", "overlap_pct"],
