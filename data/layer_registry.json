    "lay_category": "none",
    "cable_families": ["INSTR_SCREENED"],
    "notes": "Al Mylar + PE laminate tape, second layer of individual pair screen; default 40 microns, 15% overlap, density 1.50 g/cm³"
  },

  "drain_wire": {
    "display_name": "Drain Wire",
    "formula_type": "fixed_weight",
    "required_inputs": ["n_pairs"],
    "tolerance_applicable": false,
    "lay_category": "none",
    "cable_families": ["INSTR_SCREENED"],
    "notes": "Bare copper drain wire (7/0.3mm or 0.5mm²) alongside each pair screen; fixed weight 4.5 kg/km costing / 3.0 kg/km production per pair; also bumps under-screen OD by 0.5mm"
